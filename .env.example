# =============================================================================
# Multi-Agent Web Agency — local environment template
# Copy to `.env` and fill in values. Never commit real keys.
# =============================================================================

# --- Server ingress ---
PORT=3000
NODE_ENV=development
APP_URL="http://localhost:3000"

# --- AI orchestration (Nvidia NIM + LangGraph) ---
# Get your API key from: https://build.nvidia.com
NVIDIA_API_KEY=""
NVIDIA_MODEL="nvidia/nemotron-3-super-120b-a12b"

# Python LangGraph + ChatNVIDIA (primary orchestrator)
# Run: cd agents && pip install -r requirements.txt && uvicorn server:app --port 8001
AGENTS_PYTHON_URL="http://localhost:8001"

# --- Lighthouse audits (local Chrome — no Google API key) ---
# CHROME_PATH="/usr/bin/google-chrome"
# LIGHTHOUSE_MAX_CONCURRENT=4
# LIGHTHOUSE_TIMEOUT_MS=120000

# --- Database persistence (Phase 2 — pick one stack) ---
# Prisma / SQLite (local dev)
DATABASE_URL="file:./dev.db"
# Supabase (production CRM — optional until Phase 2)
# SUPABASE_URL=""
# SUPABASE_ANON_KEY=""
# SUPABASE_SERVICE_ROLE_KEY=""

# --- Optional outbound mailer (Phase 5) ---
RESEND_API_KEY=""

# --- Optional video presenter (Phase 5 — HITL-gated) ---
HEYGEN_API_KEY=""

# --- Phase 2+ (not yet wired) ---
# OUTSCRAPER_API_KEY=""
# GOOGLE_PLACES_API_KEY=""
# META_GRAPH_TOKEN=""
# VERCEL_TOKEN=""
