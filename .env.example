# NVIDIA NIM — used by LangChain / LangGraph agents
NVIDIA_API_KEY="nvapi-MY_NVIDIA_API_KEY"
NVIDIA_MODEL="deepseek-ai/deepseek-v3.1"

# Python LangGraph + ChatNVIDIA orchestrator (recommended heart of the project)
# Run: cd agents && pip install -r requirements.txt && uvicorn server:app --port 8001
AGENTS_PYTHON_URL="http://localhost:8001"

# APP_URL: Public base URL (Vercel production URL or custom domain)
APP_URL="MY_APP_URL"

# Lighthouse audits — no API key required (uses local Chrome)
# Optional: path to Chrome/Chromium binary on Linux servers
# CHROME_PATH="/usr/bin/google-chrome"
# LIGHTHOUSE_MAX_CONCURRENT=4
# LIGHTHOUSE_TIMEOUT_MS=120000

# --- Phase 2+ (not yet wired) ---
